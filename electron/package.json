{
  "name": "acoustik",
  "version": "1.0.0",
  "description": "Акустик — расчёт уровней шума для строительных площадок",
  "main": "dist/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "package": "electron-builder",
    "test": "vitest run"
  },
  "keywords": ["acoustics", "noise", "electron"],
  "author": "YuliyaSkryabina",
  "license": "MIT",
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.0",
    "electron": "^31.0.0",
    "electron-builder": "^25.0.0",
    "electron-vite": "^2.3.0",
    "typescript": "^5.5.0",
    "vite": "^5.3.0",
    "vitest": "^2.0.0",
    "@types/node": "^20.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0"
  },
  "dependencies": {
    "dxf-parser": "^1.1.2",
    "konva": "^9.3.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "react-konva": "^18.2.10",
    "zustand": "^4.5.0"
  },
  "build": {
    "appId": "ru.acoustik.app",
    "productName": "Акустик",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "resources/**/*"
    ],
    "win": {
      "target": "nsis",
      "icon": "resources/icon.ico"
    },
    "extraResources": [
      {
        "from": "../",
        "to": "app",
        "filter": ["core/**", "api/**", "requirements.txt"]
      }
    ]
  }
}
